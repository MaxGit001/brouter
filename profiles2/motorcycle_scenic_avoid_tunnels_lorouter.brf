#
# Motorcycle scenic / avoid tunnels profile for LocusMap LoRouter
# Based on current LocusMap LoCarVarioEco.brf (KinematicModel).
# Uses current allow_* switch style and avoids unsupported lookup keys.
# Car-Routing based on a kinematic model
#
# Depending on the vmax-parameter (target-speed)
# this can be anything from least-time routing to eco-routing
#
################################################################
# Asamm routing: profile adapted from 'car-vario.brf'
# 1.2021
################################################################
#
---model:btools.router.KinematicModel

---context:global

# Car profile
assign validForCars        = true

# Use the following switches to change behaviour

assign allow_toll          = true   # %allow_toll% | Allow paid roads | boolean
assign allow_unpaved       = false  # %allow_unpaved% | Allow unpaved roads, if possible | boolean
assign allow_motorways     = true   # %allow_motorways% | Allow motorways | boolean
assign allow_ferries       = true   # %allow_ferries% | Allow ferries | boolean

# Motorcycle scenic switches
assign avoid_tunnels       = true   # %avoid_tunnels% | Avoid tunnels if possible | boolean
assign tunnel_avoidance    = 2      # %tunnel_avoidance% | Tunnel avoidance strength | [0=off, 1=medium, 2=strong, 3=extreme]
assign city_avoidance      = 2      # %city_avoidance% | City avoidance strength | [0=off, 1=medium, 2=strong, 3=extreme]
assign prefer_scenic_roads = true   # %prefer_scenic_roads% | Prefer rural/pass roads | boolean
assign avoid_small_bad_roads = true # %avoid_small_bad_roads% | Prefer paved rural roads | boolean

# Remap to previously used negative logic TODO - get rid of unnecesary remaping?
assign avoid_toll = not allow_toll
assign avoid_unpaved = not allow_unpaved
assign avoid_motorways = not allow_motorways
assign avoid_ferries = not allow_ferries

# Kinematic model parameters
assign vmax             = 85     # Target speed (in km/h), scenic motorcycle default | number
assign recup_efficiency = 0.7    # (ratio) | number
assign totalweight      = 1640   # Total weight of the car (in kg) | number
assign f_roll           = 232    # Rolling friction (in Newton) | number
assign f_air            = 0.4    # Drag force (in Newton / (m/s)^2), 0.5*cw*A*rho | number
assign f_recup          = 400    # Newton | number
assign p_standby        = 250    # Watt | number

# Turn instructions settings
assign turnInstructionMode          = 2     # Mode for the generated turn instructions | [0=none, 1=auto-choose, 2=locus-style, 3=osmand-style, 4=comment-style, 5=gpsies-style, 6=orux-style]
assign turnInstructionCatchingRange = 20

# Technical parameters
assign pass1coefficient    = 1.3

assign processUnusedTags    1 # 1 is old Brouter behaviour, 0 is new Brouter default, more efficient, but ignores tags not used by a profile. We need all tags for warnings.

---context:way   # following code refers to way-tags

# classifier constants
assign classifier_none        = 1
assign classifier_ferry       = 2

assign is_avoided_toll_road and  avoid_toll toll=yes
assign is_avoided_motorway and avoid_motorways highway=motorway|motorway_link 
assign is_avoided_ferry and avoid_ferries route=ferry 


#
# calculate logical car access
#
assign isresidentialorliving = or highway=residential|living_street living_street=yes

assign caraccess
       switch motorcar=
              switch motor_vehicle=
                     switch vehicle=
                            switch access=
                                   switch highway=motorway|motorway_link    1
                                   switch highway=trunk|trunk_link          1
                                   switch highway=primary|primary_link      1
                                   switch highway=secondary|secondary_link  1
                                   switch highway=tertiary|tertiary_link    1
                                   switch highway=unclassified              1
                                   switch route=ferry                       1
                                   switch isresidentialorliving             1
                                   switch highway=service                   1
                                   switch highway=track                     1
                                   switch highway=proposed                  0
                                   switch highway=construction              0
                                   switch highway=abandoned                 0
                                   0
                                   access=yes|permissive|designated|destination|unknown
                            vehicle=yes|designated|destination|unknown
                     motor_vehicle=yes|permissive|designated|destination|unknown
              motorcar=yes|permissive|designated|destination|unknown

assign caraccess_destination
       switch motorcar=
              switch motor_vehicle=
                     switch vehicle=
                            access=destination
                            vehicle=destination
                     motor_vehicle=destination
              motorcar=destination

#
# for any change in initialclassifier, initialcost is added once
#
assign initialclassifier =
     if route=ferry then classifier_ferry
     else classifier_none


#
# calculate the initial cost
# this is added to the total cost each time the costfactor
# changed
#
assign initialcost =
     if      ( equal initialclassifier classifier_ferry       ) then 10000
     else 0

assign accessspeedlimit = if caraccess then 999 else 0

assign isbadoneway = if reversedirection=yes then ( if oneway= then junction=roundabout else oneway=yes|true|1 ) else oneway=-1
assign onewayspeedlimit = if isbadoneway then 0 else 999

assign islinktype = highway=motorway_link|trunk_link|primary_link|secondary_link|tertiary_link

# Motorcycle scenic tuning ----------------------------------------------------
# KinematicModel routing is mainly influenced by maxspeed/minspeed.
# Therefore long tunnels and urban roads are penalized by speed caps.
# Avoids unsupported shelter/gallery lookup keys that some LoRouter tables reject.
assign tunnel_speedcap =
  if ( or ( not avoid_tunnels ) ( equal tunnel_avoidance 0 ) ) then 999
  else if tunnel=yes then
    ( if greater tunnel_avoidance 2 then 8
      else if equal tunnel_avoidance 2 then 12
      else 20 )
  else 999

assign city_speedcap =
  if equal city_avoidance 0 then 999
  else if highway=living_street then
    ( if greater city_avoidance 2 then 8
      else if equal city_avoidance 2 then 12
      else 18 )
  else if highway=residential then
    ( if greater city_avoidance 2 then 12
      else if equal city_avoidance 2 then 18
      else 25 )
  else if highway=service then
    ( if greater city_avoidance 2 then 12
      else if equal city_avoidance 2 then 20
      else 30 )
  else if highway=pedestrian then 5
  else if maxspeed=30 then
    ( if greater city_avoidance 2 then 15
      else if equal city_avoidance 2 then 22
      else 30 )
  else if maxspeed=urban then
    ( if greater city_avoidance 2 then 35
      else if equal city_avoidance 2 then 42
      else 50 )
  else 999

assign scenic_speedcap =
  if not prefer_scenic_roads then 999
  else if highway=motorway|motorway_link then 65
  else if highway=trunk|trunk_link then 70
  else if highway=primary|primary_link then 85
  else if islinktype then 55
  else 999

assign badroad_speedcap =
  if not avoid_small_bad_roads then 999
  else if highway=track|path|road|bridleway then 15
  else if surface=fine_gravel then 20
  else 999

assign maxspeed_surface =
  switch or surface= surface=paved|asphalt|concrete 999
  switch surface=chipseal 80
  switch surface=compacted 40
  switch surface=paving_stones|cobblestone|sett|unpaved|gravel 30
  switch surface=ground|dirt|grass|earth|grass_paver 20
  switch surface=wood|mud|clay|metal|unhewn_cobblestone 10
  switch surface=fine_gravel ( switch avoid_unpaved 10 40 )
  switch avoid_unpaved 10 40

assign maxspeed_tracktype =
  switch tracktype= 999
  switch tracktype=grade1 40
  switch tracktype=grade2 ( switch avoid_unpaved 2 5 )
  1

assign maxspeed_implicit =
  switch highway=motorway                  999
  switch highway=motorway_link             130
  switch highway=trunk                     250
  switch highway=trunk_link                100
  switch highway=primary|primary_link      100
  switch highway=secondary|secondary_link   90
  switch highway=tertiary|tertiary_link     80
  switch highway=unclassified               50
  switch route=ferry                        10
  switch highway=bridleway                  10
  switch isresidentialorliving              30
  switch highway=service                    30
  switch highway=track|road|path 
       switch tracktype=grade1 20
       switch tracktype=grade2 5
       switch tracktype=grade3 2
       switch tracktype=grade4 0
       switch tracktype=grade5 0
       0
  0

assign maxspeed_forward =
  switch maxspeed:forward=50 50
  switch maxspeed:forward=30 30
  switch maxspeed:forward=10 10
  switch maxspeed:forward=20 20
  switch maxspeed:forward=40 40
  switch maxspeed:forward=60 60
  switch maxspeed:forward=70 70
  switch maxspeed:forward=80 80
  switch maxspeed:forward=90 90
  switch maxspeed:forward=100 100
  switch maxspeed:forward=110 110
  switch maxspeed:forward=120 120
  switch maxspeed:forward=130 130
  switch maxspeed:forward=urban 50
  switch maxspeed:forward=rural 100
  999

assign maxspeed_backward =
  switch maxspeed:backward=50 50
  switch maxspeed:backward=30 30
  switch maxspeed:backward=10 10
  switch maxspeed:backward=20 20
  switch maxspeed:backward=40 40
  switch maxspeed:backward=60 60
  switch maxspeed:backward=70 70
  switch maxspeed:backward=80 80
  switch maxspeed:backward=90 90
  switch maxspeed:backward=100 100
  switch maxspeed:backward=110 110
  switch maxspeed:backward=120 120
  switch maxspeed:backward=130 130
  switch maxspeed:backward=urban 50
  switch maxspeed:backward=rural 100
  999

assign maxspeed_explicit =
  switch maxspeed=50 50
  switch maxspeed=30 30
  switch maxspeed=10 10
  switch maxspeed=20 20
  switch maxspeed=40 40
  switch maxspeed=60 60
  switch maxspeed=70 70
  switch maxspeed=80 80
  switch maxspeed=90 90
  switch maxspeed=100 100
  switch maxspeed=110 110
  switch maxspeed=120 120
  switch maxspeed=130 130
  switch maxspeed=urban 50
  switch maxspeed=rural 100
  if reversedirection=yes then maxspeed_backward else maxspeed_forward

assign maxspeed =
  min if is_avoided_toll_road then 0 else 999
  min if is_avoided_motorway then 0 else 999
  min if is_avoided_ferry then 0 else 999
  min onewayspeedlimit
  min accessspeedlimit
  min maxspeed_explicit
  min maxspeed_implicit
  min tunnel_speedcap
  min city_speedcap
  min scenic_speedcap
  min badroad_speedcap
  min maxspeed_surface maxspeed_tracktype

assign costfactor = if equal maxspeed 0 then 10000 else 0

assign minspeed =
    if prefer_scenic_roads then 0 else switch highway=motorway|motorway_link|trunk 75 0

# way priorities used for voice hint generation

assign priorityclassifier =

  if      ( highway=motorway                  ) then  30
  else if ( highway=motorway_link             ) then  29
  else if ( highway=trunk                     ) then  28
  else if ( highway=trunk_link                ) then  27
  else if ( highway=primary                   ) then  26
  else if ( highway=primary_link              ) then  25
  else if ( highway=secondary                 ) then  24
  else if ( highway=secondary_link            ) then  23
  else if ( highway=tertiary                  ) then  22
  else if ( highway=tertiary_link             ) then  21
  else if ( highway=unclassified              ) then  20
  else if ( isresidentialorliving             ) then  6
  else if ( highway=service                   ) then  6
  else if ( highway=track                     ) then if tracktype=grade1 then 4 else 2
  else if ( highway=bridleway|road            ) then  2
  else 0

# some more classifying bits used for voice hint generation...

assign isgoodoneway = if reversedirection=yes then oneway=-1
                      else if oneway= then junction=roundabout else oneway=yes|true|1
assign isroundabout = junction=roundabout
assign isgoodforcars = if greater priorityclassifier 6 then true
                  else if or isresidentialorliving highway=service then true
                  else if ( and highway=track tracktype=grade1 ) then true
                  else false

# ... encoded into a bitmask

assign classifiermask add          isbadoneway
                      add multiply isgoodoneway   2
                      add multiply isroundabout   4
                      add multiply islinktype     8
                      add multiply isgoodforcars 16
                      add multiply isresidentialorliving 32
                          multiply caraccess_destination 64

---context:node  # following code refers to node tags

#
# calculate logical car access to nodes
#
assign caraccess
       switch motorcar=
              switch motor_vehicle=
                     switch vehicle=
                            switch access=
                                   not barrier=gate|swing_gate|bollard|lift_gate|cycle_barrier
                                   access=yes|permissive|designated|destination|unknown
                            vehicle=yes|permissive|designated|destination|unknown
                     motor_vehicle=yes|permissive|designated|destination|unknown
              motorcar=yes|permissive|designated|destination|unknown

assign initialcost =
       switch and avoid_toll barrier=toll_booth 1000000
       switch caraccess
              0
              1000000

assign maxspeed =

       if or crossing=traffic_signals highway=traffic_signals
       then
         switch greater way:priorityclassifier 24 5
         switch greater way:priorityclassifier 22 3
         switch greater way:priorityclassifier 20 1
         0
       else if railway=level_crossing then 0
       else 999
